	measure Cost_€_per_MWh_per_muni =
			
			CALCULATE(
			    MAX('Cost'[LCOE municipality (€/MWh)]),
			    TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			    TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not]),
