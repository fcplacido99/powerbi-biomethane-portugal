	measure Variancia_media_nacional = ```
			
			VAR _municipal = [Avg_cost_€_per_Nm3_municipal]
			VAR _nacional = [Avg_cost_€_per_Nm3]
			VAR _diff = _municipal - _nacional
			VAR _sign = IF(_diff>0, "+", "")
			RETURN 
			    _sign & FORMAT(_diff, "##0.000") & " €/Nm³"
			```
		lineageTag: e4b0361d-34dc-462b-9a25-1380b3f90fc7

	measure Units_variancia_cost = ```
			
			VAR _municipal = [Avg_cost_€_per_Nm3_municipal]
			VAR _nacional = [Avg_cost_€_per_Nm3]
			VAR _diff = _municipal - _nacional
			VAR _varpercentage = (_diff/_nacional)*100
			VAR _uparrow = UNICHAR(129129)
			VAR _downarrow = UNICHAR(129131)
			RETURN
			IF(_varpercentage < 0, 
			ROUND(_varpercentage,2) & "%" & _downarrow,
			"+" & ROUND(_varpercentage,2) & "%" & _uparrow) 
			```
		lineageTag: 063c9c52-0cbf-4743-a3d5-55d9f9b7710a

