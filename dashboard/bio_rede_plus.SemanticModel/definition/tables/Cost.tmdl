	measure Cost_total_sum =
			
			VAR totalCost_selectedMuni =
			    SUMX(
			        VALUES('Municipality'[Municipality]),
			        VAR cost_muni =
			            CALCULATE(
			                MAX('Cost'[TOTAL €/Nm-3]),
			                TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			                TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not]),
			                TREATAS(VALUES('Practice'[Practice]), 'Cost'[Practice])
			            )
			        VAR out_muni =
			            CALCULATE(
			                SUM('Cost'[BioRefinery Scale Output Nm⁻³ ])
			            )
			        RETURN
			            cost_muni * out_muni
			    )
			RETURN
			IF(
			    HASONEVALUE('Municipality'[Municipality]) || ISFILTERED('Municipality'[Municipality]),
			    totalCost_selectedMuni,
			    [Median_cost_€/Nm3_Portugal]
			)
			
			
			//IF (
			//    ISFILTERED('Municipality'[Municipality]),
			//    SUM(Cost[TOTAL €/Nm-3])*SUM(Cost[BioRefinery Scale Output Nm⁻³ ]),
			//    MEDIAN(Cost[TOTAL €/Nm-3])
			//)
		lineageTag: b95ae73d-b52e-4a9d-ae66-ac51880207d8

		annotation PBI_FormatHint = {"isGeneralNumber":true}

