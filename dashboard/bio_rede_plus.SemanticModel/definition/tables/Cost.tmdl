			)
		lineageTag: d07bc866-ae75-4745-8f14-3fc784fd4da4

	measure Median_cost_€/Nm3_Portugal =
			
			VAR muniAll =
			    ALL('Municipality'[Municipality])
			VAR muniWithData =
			    FILTER(
			        muniAll,
			        NOT ISBLANK(
			            CALCULATE(
			                MAX('Cost'[TOTAL €/Nm-3]),
			                TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			                TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not])
			            )
			        )
			    )
			RETURN
			MEDIANX(
			    muniWithData,
			    CALCULATE(
			        MAX('Cost'[TOTAL €/Nm-3]),
			        TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			        TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not])
			    )
			)
		lineageTag: 47034f00-6e14-49f6-8dbd-86ca074e96dc

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Median_cost_€/Nm3_current =
			
			VAR muniSel = VALUES('Municipality'[Municipality])
			VAR muniWithData =
			    FILTER(
			        muniSel,
			        NOT ISBLANK( CALCULATE([Cost_€_per_MWh_per_muni]) )
			    )
			RETURN
			MEDIANX(
			    muniWithData,
			    CALCULATE([Cost_€_per_MWh_per_muni])
			)
		lineageTag: df513075-3a97-4de7-97e7-7da15f04de47

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Cost_total_or_median =
			
			VAR muniSel = VALUES('Municipality'[Municipality])
			VAR nMuni   = COUNTROWS(muniSel)
			
			VAR cost_single =
			    CALCULATE(
			        SUM('Cost'[TOTAL €/Nm-3]),
			        TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			        TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not]),
			        TREATAS(VALUES('Practice'[Practice]), 'Cost'[Practice])
			    )
			    *
			    CALCULATE(
			        SUM('Cost'[BioRefinery Scale Output Nm⁻³ ]),
			        TREATAS(VALUES('Supply'[Supply]), 'Cost'[Supply]),
			        TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost'[CHP_or_not]),
			        TREATAS(VALUES('Practice'[Practice]), 'Cost'[Practice])
			    )
			
			VAR muniWithData =
			    FILTER(
			        muniSel,
			        NOT ISBLANK( CALCULATE([Cost_€_per_Nm3_per_muni]) )
			    )
			
			VAR median_cost =
			    AVERAGEX(
			        muniWithData,
			        CALCULATE([Cost_€_per_Nm3_per_muni])
			    )
			
			RETURN
			SWITCH(
			    TRUE(),
			    nMuni = 1, cost_single,
			    -- 0 or 2+ municipalities: median €/Nm³ of the municipalities currently in context
			    median_cost
			)
		lineageTag: 1e7f5e11-5251-4765-9c13-517fce05e237

		annotation PBI_FormatHint = {"isGeneralNumber":true}

