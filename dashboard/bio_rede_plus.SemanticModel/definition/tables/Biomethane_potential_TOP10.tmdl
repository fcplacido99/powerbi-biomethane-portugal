table Biomethane_potential_TOP10
	lineageTag: a9fefaaf-6fa3-41b0-b46e-37ebecf7b424

	measure MunicipalityRank_biomet =
			
			RANKX(
			    ALL(Biomethane_potential_TOP10[Municipality]),
			    CALCULATE(SUM(Biomethane_potential_TOP10[Total Biomethane Production (Nm³)])),
			    ,
			    DESC,
			    DENSE
			)
		formatString: 0
		lineageTag: 593dc27a-3afd-44c3-9089-2a9eb0952791

	measure RankWithSymbol_biomet = FORMAT([MunicipalityRank_biomet], "#") & "º"
		lineageTag: 7a370f68-d20c-4390-8f2c-491906d9ca07

	measure Municipality_Tooltip_Line_TOP10 =
			
			"Municipality"
		lineageTag: d230d6bd-2db8-49fc-b914-ae643300abae

	measure Biomethane_Tooltip_Line_TOP10 = ```
			
			IF([Area_selected] = "Total",
			    "Total Biomethane Production (kNm³)",
			    "Total Biomethane Production (kNm³/km²)"
			    )
			
			```
		lineageTag: 13f0506f-b4c5-49a1-b004-72699d967de8

