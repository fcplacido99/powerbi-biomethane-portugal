	column Biomethane_Display_TOP10 =
			
			VAR s = FORMAT('Biomethane_potential_TOP10'[Total Biomethane Production (KNm³)], "#,##0", "pt-PT")   //"en-US")
			
			RETURN
			    SUBSTITUTE(
			        SUBSTITUTE(s, UNICHAR(160), "."),   -- NBSP
			        " ",
			        "."                                 -- normal space (just in case)
			    )
		lineageTag: 136b195a-b1fb-43ea-9c95-5f93d7a70f68
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

