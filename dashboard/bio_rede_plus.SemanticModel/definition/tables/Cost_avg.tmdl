	measure Avg_cost_€_per_Nm3_avg =
			
			CALCULATE(
			    AVERAGEX(
			        VALUES('Municipality'[Municipality]),
			        CALCULATE( SUM('Cost_avg'[TOTAL €/Nm-3]) )
			    ),
			    REMOVEFILTERS('Municipality')
			)
		lineageTag: 705202ee-c250-4d12-b414-00f9214e5d8f

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Avg_cost_€_per_Nm3_municipal_avg =
			
			VAR _oneMun = HASONEVALUE('Municipality'[Municipality])
			RETURN
			IF(
			    _oneMun,
			    -- single municipality: just its value
			    SUM('Cost_avg'[TOTAL €/Nm-3]),
			    -- multiple (or none): average across the municipalities currently selected
			    AVERAGEX(
			        VALUES('Municipality'[Municipality]),
			        CALCULATE( SUM('Cost_avg'[TOTAL €/Nm-3]) )
			    )
			)
		lineageTag: 17b93d70-288e-415c-9ee1-1b7f33df28a9

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure LCOE_Avg_cost_€_per_MWh_avg = ```
			
			VAR _pci_GJ_per_NM3 = 0.03797
			VAR _pci_MWh_per_NM3 = _pci_GJ_per_NM3*(1/3.6)
			VAR _LCOE_volume = [Avg_cost_€_per_Nm3_avg]
			RETURN
			    _LCOE_volume/_pci_MWh_per_NM3
			
			```
		lineageTag: b91eca32-00b2-4600-a18e-f21325029d57

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure LCOE_Avg_cost_€_per_MWh_municipal_avg =
			
			VAR _pci_GJ_per_NM3 = 0.03797
			VAR _pci_MWh_per_NM3 = _pci_GJ_per_NM3*(1/3.6)
			VAR _LCOE_volume = [Avg_cost_€_per_Nm3_municipal_avg]
			RETURN
			    _LCOE_volume/_pci_MWh_per_NM3
