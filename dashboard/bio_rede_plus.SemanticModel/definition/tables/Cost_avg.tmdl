table Cost_avg
	lineageTag: b95f6428-107e-4515-99a5-34ebba37ec8d

	measure Input_sum_avg =
			IF (
			    ISFILTERED('Cost_avg'[Municipality]),
			    SUM('Cost_avg'[BioReferiny Scale Input (tonnes)])/1000,
			    SUM('Cost_avg'[BioReferiny Scale Input (tonnes)])/1000
			)
		lineageTag: 6c14079b-a6b9-4fe5-a2d5-4641b319b576

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Output_sum_avg =
			IF (
			    ISFILTERED('Cost_avg'[Municipality]),
			    SUM('Cost_avg'[BioRefinery Scale Output Nm⁻³ ])/1000,
			    SUM('Cost_avg'[BioRefinery Scale Output Nm⁻³ ])/1000
			)
		lineageTag: 54b736eb-af8e-4256-9109-eff11e4c2780

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure KPI_input_kt_avg = ```
			
			SWITCH(
			    TRUE(),
			    [Input_sum_avg] > 10,
			        FORMAT([Input_sum_avg], "#,##0") & " kt",
			    [Input_sum_avg] > 1 && [Input_sum_avg] <= 10,
			        FORMAT([Input_sum_avg], "#,##0.0") & " kt",
			    [Input_sum_avg] <= 1, 
			        FORMAT([Input_sum_avg], "#,##0.00") & " kt"
			)
			```
		lineageTag: cfd4cd1a-b479-4396-af5a-5075d62f66e4

	measure KPI_output_kt_avg = ```
			
			SWITCH(
			    TRUE(),
			    [Output_sum_avg] > 10,
			        FORMAT([Output_sum_avg], "#,##0") & " kNm³",
			    [Output_sum_avg] > 1 && [Output_sum_avg] <= 10,
			        FORMAT([Output_sum_avg], "#,##0.0") & " kNm³",
			    [Output_sum_avg] <= 1, 
			        FORMAT([Output_sum_avg], "#,##0.00") & " kNm³"
			)
			```
		lineageTag: 5a36cd1d-10f5-404e-89e6-0fad1a3e27ba

	measure Cost_total_sum_avg = ```
			IF (
			    ISFILTERED('Municipality'[Municipality]),
			    SUM(Cost_avg[TOTAL €/Nm-3])*SUM(Cost_avg[BioRefinery Scale Output Nm⁻³ ]),
			    MEDIAN(Cost_avg[TOTAL €/Nm-3])
			)
			
			
			```
