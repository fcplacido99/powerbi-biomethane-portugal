	measure KPI_AC_Standard_avg = "Standard practice: " & FORMAT([AbatementCost_avg_Standard], "#,##0.00") & " €/tCO₂e"
		lineageTag: 220789bf-9db5-4aa3-a649-9ac6419a4f85

	measure Cost_total_or_median_avg =
			
			VAR muniSel = VALUES('Municipality'[Municipality])
			VAR nMuni   = COUNTROWS(muniSel)
			
			VAR cost_single =
			    CALCULATE(
			        SUM('Cost_avg'[TOTAL €/Nm-3]),
			        TREATAS(VALUES('Supply'[Supply]), 'Cost_avg'[Supply]),
			        TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost_avg'[CHP_or_not]),
			        TREATAS(VALUES('Practice'[Practice]), 'Cost_avg'[Practice])
			    )
			    *
			    CALCULATE(
			        SUM('Cost_avg'[BioRefinery Scale Output Nm⁻³ ]),
			        TREATAS(VALUES('Supply'[Supply]), 'Cost_avg'[Supply]),
			        TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost_avg'[CHP_or_not]),
			        TREATAS(VALUES('Practice'[Practice]), 'Cost_avg'[Practice])
			    )
			
			VAR muniWithData =
			    FILTER(
			        muniSel,
			        NOT ISBLANK( CALCULATE([Cost_€_per_Nm3_per_muni_avg]) )
			    )
			
			VAR median_cost =
			    MEDIANX(
			        muniWithData,
			        CALCULATE([Cost_€_per_Nm3_per_muni_avg])
			    )
			
			RETURN
			SWITCH(
			    TRUE(),
			    nMuni = 1, cost_single,
			    -- 0 or 2+ municipalities: median €/Nm³ of the municipalities currently in context
			    median_cost
			)
		lineageTag: 0ca8dfc1-d01c-4c6e-8f12-52f640f4e704

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Cost_€_per_Nm3_per_muni_avg =
			
			CALCULATE(
			    MAX('Cost_avg'[TOTAL €/Nm-3]),
			    TREATAS(VALUES('Supply'[Supply]), 'Cost_avg'[Supply]),
			    TREATAS(VALUES('CHP'[CHP_or_not]), 'Cost_avg'[CHP_or_not]),
			    TREATAS(VALUES('Practice'[Practice]), 'Cost_avg'[Practice])
			)
		lineageTag: 1eca74ff-53ed-4e60-a05e-cf24d7f586fa

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure LCOE_Avg_cost_€_per_MWh_adaptive_avg =
			
			VAR _pci_GJ_per_NM3  = 0.03797
			VAR _pci_MWh_per_NM3 = _pci_GJ_per_NM3 / 3.6
			VAR v = [Avg_cost_€_per_Nm3_adaptive_avg]
			RETURN
			DIVIDE(v, _pci_MWh_per_NM3)
		lineageTag: 3c1a7cdf-3044-4cc8-aed0-85442791d925

	measure Avg_cost_€_per_Nm3_adaptive_avg =
			
			VAR muniSel = VALUES('Municipality'[Municipality])
			VAR nMuni   = COUNTROWS(muniSel)
			VAR muniWithData =
			    FILTER(
			        muniSel,
			        NOT ISBLANK( CALCULATE([Cost_€_per_Nm3_per_muni_avg]) )
			    )
			RETURN
			SWITCH(
			    TRUE(),
			    nMuni = 0,
			        AVERAGEX(muniWithData, CALCULATE([Cost_€_per_Nm3_per_muni_avg])),
			    nMuni = 1,
			        CALCULATE([Cost_€_per_Nm3_per_muni_avg]),
			    AVERAGEX(muniWithData, CALCULATE([Cost_€_per_Nm3_per_muni_avg]))
			)
		lineageTag: 03929c56-f491-4bb9-a72c-5fb0cc7b5226

		annotation PBI_FormatHint = {"isGeneralNumber":true}

